@model IEnumerable<DonorTrackingSystem.Models.NonCongregant>
@{
    ViewData["Title"] = "View Non-Congregant Donors";
}

<!-- Container for viewing all non-congregant donors -->
<div class="container mt-4">
    <!-- Page header -->
    <div class="row mb-3">
        <div class="col-12">
            <h2>Non-Congregant Donors</h2>
            <hr />
        </div>
    </div>

    <!-- Success message notification -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Navigation buttons -->
    <div class="d-flex justify-content-between mb-3">
        <!-- Button to add a new non-congregant donor -->
        <a asp-action="AddNonCongregant" class="btn btn-primary">
            <i class="bi bi-person-fill-add"></i> Add Non-Congregant Donor
        </a>
        <!-- Button to return to dashboard -->
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-house"></i> Back to Dashboard
        </a>
    </div>

    <!-- Main non-congregant donors table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <!-- Make table scrollable on small screens -->
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Name</th>
                                    <th>Company/Organization</th>
                                    <th>Contact Details</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Check if there are non-congregants to display -->
                                @if (Model != null && Model.Any())
                                {
                                    <!-- Loop through each non-congregant -->
                                    @foreach (var nonCongregant in Model)
                                    {
                                        <tr>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(nonCongregant.FirstName) || !string.IsNullOrWhiteSpace(nonCongregant.LastName))
                                                {
                                                    <!-- Display full name if available -->
                                                    <span>@nonCongregant.FirstName @nonCongregant.LastName</span>
                                                }
                                                else
                                                {
                                                    <!-- Show dash if no name -->
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(nonCongregant.CompanyOrganization))
                                                {
                                                    <!-- Display company/org if available -->
                                                    <span class="badge bg-info">@nonCongregant.CompanyOrganization</span>
                                                }
                                                else
                                                {
                                                    <!-- Show dash if no company -->
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(nonCongregant.ContactDetails))
                                                {
                                                    <!-- Truncate long contact details -->
                                                    @(nonCongregant.ContactDetails.Length > 50 
                                                        ? nonCongregant.ContactDetails.Substring(0, 50) + "..." 
                                                        : nonCongregant.ContactDetails)
                                                }
                                                else
                                                {
                                                    <!-- Show dash if no contact info -->
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <!-- Message when no non-congregants exist -->
                                    <tr>
                                        <td colspan="4" class="text-center">No non-congregant donors found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary card (only shown if non-members exist) -->
    @if (Model != null && Model.Any())
    {
        <div class="row mt-3">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Summary</h5>
                        <!-- Count total number of non-member donors -->
                        <p><strong>Total Non-Congregant Donors:</strong> @Model.Count()</p>
                        <p><strong>Individual Donors:</strong> @Model.Count(n => !string.IsNullOrWhiteSpace(n.FirstName) || !string.IsNullOrWhiteSpace(n.LastName))</p>
                        <p><strong>Organization Donors:</strong> @Model.Count(n => !string.IsNullOrWhiteSpace(n.CompanyOrganization))</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
