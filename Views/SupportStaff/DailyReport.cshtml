@model IEnumerable<DonorTrackingSystem.Models.Donation>
@{
    ViewData["Title"] = "Daily Donation Report";
}

<!-- Container for daily donation report -->
<div class="container mt-4">
    <!-- Page header with report date -->
    <div class="row mb-3">
        <div class="col-12">
            <h2>Daily Donation Report</h2>
            <p class="text-muted">Report for: @ViewBag.ReportDate.ToString("MMMM d, yyyy")</p>
            <hr />
        </div>
    </div>

    <!-- Navigation buttons -->
    <div class="d-flex justify-content-between mb-3">
        <!-- Button to record a new donation -->
        <a asp-action="RecordDonation" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Record New Donation
        </a>
        <!-- Button to return to dashboard -->
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-house"></i> Back to Dashboard
        </a>
    </div>

    <!-- Summary statistics cards -->
    <div class="row mb-4">
        <!-- Total donations card -->
        <div class="col-md-3 mb-3">
            <div class="card summary-card">
                <div class="card-body">
                    <h5>Total Donations</h5>
                    <h2 style="color: #4a90e2;">@ViewBag.TotalDonations</h2>
                </div>
            </div>
        </div>
        <!-- Total amount card -->
        <div class="col-md-3 mb-3">
            <div class="card summary-card">
                <div class="card-body">
                    <h5>Total Amount</h5>
                    <h2 style="color: #27ae60;">@ViewBag.TotalAmount.ToString("C")</h2>
                </div>
            </div>
        </div>
        <!-- Envelope donations card -->
        <div class="col-md-3 mb-3">
            <div class="card summary-card">
                <div class="card-body">
                    <h5>Envelope Donations</h5>
                    <h2 style="color: #9b59b6;">@ViewBag.EnvelopeDonations</h2>
                </div>
            </div>
        </div>
        <!-- Non-envelope donations card -->
        <div class="col-md-3 mb-3">
            <div class="card summary-card">
                <div class="card-body">
                    <h5>Other Donations</h5>
                    <h2 style="color: #e67e22;">@ViewBag.NonEnvelopeDonations</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Donations table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0">Today's Donations</h4>
                </div>
                <div class="card-body">
                    <!-- Make table scrollable on small screens -->
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Time Recorded</th>
                                    <th>Envelope #</th>
                                    <th>Donor Name</th>
                                    <th>Amount</th>
                                    <th>Fund</th>
                                    <th>Staff ID</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Check if there are donations today -->
                                @if (Model != null && Model.Any())
                                {
                                    <!-- Loop through each donation -->
                                    @foreach (var donation in Model)
                                    {
                                        <tr>
                                            <!-- Display time recorded -->
                                            <td>@donation.Created.ToLocalTime().ToString("h:mm tt")</td>

                                            <!-- Envelope Number column: show envelope # if exists, otherwise "-" -->
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(donation.EnvelopeNumber))
                                                {
                                                    <span class="badge bg-primary">@donation.EnvelopeNumber</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            
                                            <!-- Donor Name column: show congregant, non-member, or "Anonymous" -->
                                            <td>
                                                @if (donation.Congregant != null)
                                                {
                                                    <!-- Display congregant name -->
                                                    <span>@donation.Congregant.Name</span>
                                                }
                                                else if (donation.NonMember != null)
                                                {
                                                    <!-- Display non-member donor name or company -->
                                                    @if (!string.IsNullOrWhiteSpace(donation.NonMember.FirstName) || 
                                                         !string.IsNullOrWhiteSpace(donation.NonMember.LastName))
                                                    {
                                                        <span>@donation.NonMember.FirstName @donation.NonMember.LastName</span>
                                                    }
                                                    else if (!string.IsNullOrWhiteSpace(donation.NonMember.CompanyOrganization))
                                                    {
                                                        <span class="badge bg-info">@donation.NonMember.CompanyOrganization</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <!-- Show anonymous if no donor info -->
                                                    <span class="text-muted fst-italic">Anonymous</span>
                                                }
                                            </td>
                                            
                                            <!-- Display amount as currency -->
                                            <td class="fw-bold">@donation.DonationAmount.ToString("C")</td>
                                            
                                            <!-- Display fund designation -->
                                            <td>
                                                <span class="badge bg-secondary">@donation.FundDesignation?.Name</span>
                                            </td>
                                            
                                            <!-- Display staff member who recorded it -->
                                            <td>@donation.StaffMemberID</td>
                                           
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <!-- Message when no donations today -->
                                    <tr>
                                        <td colspan="6" class="text-center py-4">
                                            <i class="bi bi-inbox"></i> No donations recorded today.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

