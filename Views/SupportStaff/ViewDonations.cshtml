@model IEnumerable<DonorTrackingSystem.Models.Donation>
@{
    ViewData["Title"] = "View Donations";
}

<!-- Container for viewing all donations -->
<div class="container mt-4">
    <!-- Page header -->
    <div class="row mb-3">
        <div class="col-12">
            <h2>All Donations</h2>
            <hr />
        </div>
    </div>

    <!-- Navigation buttons -->
    <div class="row mb-3">
        <div class="col-12">
            <!-- Button to record a new donation -->
            <a asp-action="RecordDonation" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Record New Donation
            </a>
            <!-- Button to return to dashboard -->
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-house"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <!-- Main donations table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <!-- Make table scrollable on small screens -->
                    <div class="table-responsive">
                        <table class="table table-striped table-hover" id="donationsTable">
                            <thead class="table-dark">
                                <tr>
                                    <th>ID</th>
                                    <th>Date</th>
                                    <th>Donor ID</th>
                                    <th>Envelope #</th>
                                    <th>Amount</th>
                                    <th>Fund Designation</th>
                                    <th>Staff Member ID</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Check if there are donations to display -->
                                @if (Model != null && Model.Any())
                                {
                                    <!-- Loop through each donation -->
                                    @foreach (var donation in Model)
                                    {
                                        <tr>
                                            <td>@donation.ID</td>
                                            <td>@donation.DonationDate.ToShortDateString()</td>
                                            <td>@donation.DonorID</td>
                                            <!-- Show "-" if no envelope number -->
                                            <td>@(donation.EnvelopeNumber ?? "-")</td>
                                            <!-- Display amount as currency -->
                                            <td>@donation.DonationAmount.ToString("C")</td>
                                            <!-- Display fund name in a badge -->
                                            <td>
                                                <span class="badge bg-info">
                                                    @donation.FundDesignation?.Name
                                                </span>
                                            </td>
                                            <td>@donation.StaffMemberID</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <!-- Message when no donations exist -->
                                    <tr>
                                        <td colspan="7" class="text-center">No donations found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary card (only shown if donations exist) -->
    @if (Model != null && Model.Any())
    {
        <div class="row mt-3">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Summary</h5>
                        <!-- Count total number of donations -->
                        <p><strong>Total Donations:</strong> @Model.Count()</p>
                        <!-- Sum all donation amounts and format as currency -->
                        <p><strong>Total Amount:</strong> @Model.Sum(d => d.DonationAmount).ToString("C")</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
