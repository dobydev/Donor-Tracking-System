@model IEnumerable<DonorTrackingSystem.Models.Donation>
@{
    ViewData["Title"] = "Support Staff Dashboard";
}

<!-- Main dashboard container -->
<div class="container mt-4">
    <!-- Page header -->
    <div class="row">
        <div class="col-12">
            <h2 class="text-center">Support Staff Dashboard</h2>
            <hr />
        </div>
    </div>

    <!-- Success message notification (appears after recording a donation) -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Quick action buttons -->
    <div class="row mb-4 d-flex justify-content-between">
        <!-- Record new donation card -->
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Record Donation</h5>
                    <p>Enter new donation details</p>
                    <a asp-action="RecordDonation" class="btn btn-outline-secondary">
                        <i class="bi bi-plus-circle"></i> Record
                    </a>
                </div>
            </div>
        </div>
        <!-- Daily report card -->
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Daily Report</h5>
                    <p>View today's summary</p>
                    <a asp-action="DailyReport" class="btn btn-outline-secondary">
                        <i class="bi bi-calendar-check"></i> View Report
                    </a>
                </div>
            </div>
        </div>
        <!-- Manage congregants card
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Congregants</h5>
                    <p>Manage members</p>
                    <a asp-action="ViewCongregants" class="btn btn-outline-secondary">
                        <i class="bi bi-people-fill"></i> Manage
                    </a>
                </div>
            </div>
        </div>  -->
        <!-- Manage non-member donors card -->
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Non-Members</h5>
                    <p>Manage donor list</p>
                    <a asp-action="ViewNonMembers" class="btn btn-outline-secondary">
                        <i class="bi bi-people"></i> Manage
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent donations table (shows last 10 donations) -->
    <div class="row">
        <div class="col-12">
            <h4>Recent Donations</h4>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Date</th>
                            <th>Donor ID</th>
                            <th>Envelope #</th>
                            <th>Amount</th>
                            <th>Fund</th>
                            <th>Staff ID</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Check if there are any donations to display -->
                        @if (Model != null && Model.Any())
                        {
                            <!-- Loop through each donation and display in table row -->
                            @foreach (var donation in Model)
                            {
                                <tr>
                                    <td>@donation.DonationDate.ToShortDateString()</td>
                                    <td>@donation.DonorID</td>
                                    <!-- Display envelope number or "-" if none -->
                                    <td>@(donation.EnvelopeNumber ?? "-")</td>
                                    <!-- Format amount as currency -->
                                    <td>@donation.DonationAmount.ToString("C")</td>
                                    <td>@donation.FundDesignation?.Name</td>
                                    <td>@donation.StaffMemberID</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <!-- Show message when no donations exist -->
                            <tr>
                                <td colspan="6" class="text-center">No donations recorded yet.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>