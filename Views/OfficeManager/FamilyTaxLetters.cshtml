@model IEnumerable<DonorTrackingSystem.ViewModels.FamilyTaxLetterViewModel>

@{
    ViewData["Title"] = $"Family Tax Letters – {ViewBag.Year}";
    int year = (int)ViewBag.Year;
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        // Sync checkbox states with letter visibility
        function syncVisibility() {
        document.querySelectorAll('.letter-checkbox').forEach(cb => {
        const page = document.querySelector(`#letters-export .letter-page[data-key="${cb.value}"]`);
        if (page) {
        page.style.display = cb.checked ? '' : 'none';
        }
        });
        }

        // Update export button state and text based on selections
        function updateExportBtn() {
        const checked = document.querySelectorAll('.letter-checkbox:checked').length;
        const btn = document.getElementById('btn-export-pdf');

        btn.disabled = checked === 0;
        btn.innerHTML = checked === 0
        ? '<i class="bi bi-file-earmark-pdf"></i> Export PDF'
        : `<i class="bi bi-file-earmark-pdf"></i> Export Selected (${checked}) as PDF`;
        }

        // Select all checkboxes and update UI
        function selectAll() {
        document.querySelectorAll('.letter-checkbox').forEach(cb => cb.checked = true);
        syncVisibility();
        updateExportBtn();
        }

        // Deselect all checkboxes and update UI
        function deselectAll() {
        document.querySelectorAll('.letter-checkbox').forEach(cb => cb.checked = false);
        syncVisibility();
        updateExportBtn();
        }

        // Export selected letters to PDF
        function exportPdf() {
        const btn = document.getElementById('btn-export-pdf');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Generating…';

        const options = {
        margin: [0.5, 0.6],
        filename: 'FamilyTaxLetters_@(year).pdf',
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2, useCORS: true },
        jsPDF: { unit: 'in', format: 'letter', orientation: 'portrait' },
        pagebreak: { mode: ['css', 'legacy'] }
        };

        html2pdf()
        .set(options)
        .from(document.getElementById('letters-export'))
        .save()
        .then(() => {
        updateExportBtn();
        });
        }

        document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.letter-checkbox').forEach(cb => {
        cb.addEventListener('change', () => {
        syncVisibility();
        updateExportBtn();
        });
        });

        syncVisibility();
        updateExportBtn();
        });
    </script>
}

@await Html.PartialAsync("_TaxLetterStyles")

<div class="no-print container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Family Tax Letters – @year</h3>
        <div class="d-flex gap-2">
            <button id="btn-export-pdf" onclick="exportPdf()" class="btn btn-primary" disabled>
                <i class="bi bi-file-earmark-pdf"></i> Export PDF
            </button>
            <a asp-action="TaxLetters" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> No family donations recorded for @year.
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Select the families below, then click <strong>Export Selected as PDF</strong>.
        </div>

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Select Families to Include</span>
                <div class="d-flex gap-2">
                    <button type="button" onclick="selectAll()" class="btn btn-sm btn-outline-primary">Select All</button>
                    <button type="button" onclick="deselectAll()" class="btn btn-sm btn-outline-secondary">Deselect All</button>
                </div>
            </div>

            <div class="card-body" style="max-height: 260px; overflow-y: auto;">
                <div class="row">
                    @{
                        int fi = 0;
                    }

                    @foreach (var letter in Model)
                    {
                        <div class="col-md-4 col-sm-6 mb-1">
                            <div class="form-check">
                                <input class="form-check-input letter-checkbox"
                                       type="checkbox"
                                       id="chk-family-@fi"
                                       value="@fi"
                                       checked />
                                <label class="form-check-label" for="chk-family-@fi">
                                    The @letter.FamilyName Family
                                    <small class="text-muted">(@letter.Total.ToString("C"))</small>
                                </label>
                            </div>
                        </div>
                        fi++;
                    }
                </div>
            </div>
        </div>
    }
</div>

<div id="letters-export">
    @{
        int li = 0;
        int totalLetters = Model.Count();
    }

    @foreach (var letter in Model)
    {
        <div class="letter-page" data-key="@li">
            <div class="letter-church-header">
                <h3 class="mt-3"><strong>Grace Community Church</strong></h3>
                <address>
                    123 Faith Avenue<br />
                    Springfield, IL 62701<br />
                    Phone: (555) 000-0000<br />
                    EIN: 00-0000000
                </address>
                <p>
                    @(new DateTime(year, 12, 31) <= DateTime.Today
                        ? new DateTime(year, 12, 31).ToString("MMMM d, yyyy")
                        : DateTime.Today.ToString("MMMM d, yyyy"))
                </p>
            </div>

            <div class="letter-recipient">
                <strong>The @letter.FamilyName</strong><br />
                @if (!string.IsNullOrWhiteSpace(letter.RecipientAddress))
                {
                    @letter.RecipientAddress
                }
            </div>

            <strong>_________________________________________________</strong><br />
            <br />

            <div class="letter-body">
                <p>Dear @letter.FamilyName,</p>

                <p>
                    Thank you for your generous support of Grace Community Church during the @year tax year.
                    This letter serves as your official tax-deductible contribution acknowledgement for the
                    @year calendar year.
                </p>

                @if (letter.MemberNames.Count > 1)
                {
                    <p>
                        <strong>Donations included for:</strong> @string.Join(", ", letter.MemberNames)
                    </p>
                }

                <strong>_________________________________________________</strong><br />
                <br />

                <table class="letter-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Fund</th>
                            <th class="amount">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in letter.Donations)
                        {
                            <tr>
                                <td>@d.Date.ToString("MM/dd/yyyy")</td>
                                <td>@d.FundName</td>
                                <td class="amount">@d.Amount.ToString("C")</td>
                            </tr>
                        }
                        <tr class="letter-total-row">
                            <td colspan="2"><strong>Total Contributions for @year:</strong></td>
                            <td class="amount">@letter.Total.ToString("C")</td>
                        </tr>
                    </tbody>
                </table>

                <strong>_________________________________________________</strong><br />
                <br />

                <p><strong>No goods or services were provided in exchange for your contributions.</strong></p>
                <p>Please retain this letter as your official record for tax purposes.</p>
            </div>

            <div class="letter-signature">
                <div class="d-flex justify-content-start">
                    <p class="mb-0">
                        <strong>_________________________________</strong><br />
                        <strong>Office Manager</strong> |
                        Grace Community Church
                    </p>
                    <img src="~/Donor_Logo_2.png" alt="Church Logo" style="width: 150px;" />
                </div>
            </div>
        </div>

        @if (li < totalLetters - 1)
        {
            <div class="pdf-page-break"></div>
        }

        li++;
    }
</div>