@model IEnumerable<DonorTrackingSystem.Models.NonCongregant>
@{
    ViewData["Title"] = "View Non-Member Donors";
}

<!-- This view manages non-member donors -->
<div class="container mt-4">
    <!-- Page header -->
    <div class="row mb-3">
        <div class="col-12">
            <h2>Non-Member Donors</h2>
            <hr />
        </div>
    </div>

    <!-- Success message notification -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Navigation buttons -->
    <div class="d-flex justify-content-between mb-3">
        <a asp-controller="SupportStaff" asp-action="AddNonCongregant" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Non-Congregant Donor
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-house"></i> Back to Dashboard
        </a>
    </div>

    <!-- Main non-congregants table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Name</th>
                                    <th>Company/Organization</th>
                                    <th>Contact Details</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var nonCongregant in Model)
                                    {
                                        <tr>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(nonCongregant.FirstName) || !string.IsNullOrWhiteSpace(nonCongregant.LastName))
                                                {
                                                    <span>@nonCongregant.FirstName @nonCongregant.LastName</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(nonCongregant.CompanyOrganization))
                                                {
                                                    <span>@nonCongregant.CompanyOrganization</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(nonCongregant.ContactDetails))
                                                {
                                                    @(nonCongregant.ContactDetails.Length > 50
                                                        ? nonCongregant.ContactDetails.Substring(0, 50) + "..."
                                                        : nonCongregant.ContactDetails)
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (nonCongregant.IsActive)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Inactive</span>
                                                }
                                            </td>
                                            <td>
                                                <a asp-action="EditNonCongregant" asp-route-id="@nonCongregant.ID" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-pencil"></i> Edit
                                                </a>
                                                @if (!nonCongregant.IsActive)
                                                {
                                                    <!-- Show Restore button for inactive donors -->
                                                    <form asp-action="ReactivateNonCongregant" asp-route-id="@nonCongregant.ID" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to reactivate this non-congregant donor?');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-outline-success">
                                                            <i class="bi bi-arrow-counterclockwise"></i> Restore
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <!-- Show Deactivate button for active donors -->
                                                    <form asp-action="DeactivateNonCongregant" asp-route-id="@nonCongregant.ID" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to deactivate this non-congregant donor?');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                                            <i class="bi bi-trash"></i> Deactivate
                                                        </button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center">No non-member donors found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary card -->
    @if (Model != null && Model.Any())
    {
        <div class="row mt-3">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Summary</h5>
                        <p><strong>Total Non-Member Donors:</strong> @Model.Count()</p>
                        <p><strong>Active:</strong> @Model.Count(n => n.IsActive)</p>
                        <p><strong>Inactive:</strong> @Model.Count(n => !n.IsActive)</p>
                    </div>
                </div>
            </div>
        </div>
    }

</div>
