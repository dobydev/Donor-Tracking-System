@model IEnumerable<DonorTrackingSystem.Models.Congregant>
@{
    ViewData["Title"] = "Congregant Report";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2>Congregant Report</h2>
            <a asp-action="ExportCongregantReport" class="btn btn-outline-success">
                <i class="bi bi-download"></i> Export CSV
            </a>
        </div>
        <div class="col-12"><hr /></div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Address</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th>Birth Date</th>
                    <th>Join Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Name</td>
                        <td>@c.Address</td>
                        <td>@c.PhoneNumber</td>
                        <td>@c.EmailAddress</td>
                        <td>@c.BirthDate?.ToString("MM/dd/yyyy")</td>
                        <td>@c.JoinDate?.ToString("MM/dd/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <a asp-action="Reports" class="btn btn-secondary mt-2"><i class="bi bi-arrow-left"></i> Back to Reports</a>
</div>
