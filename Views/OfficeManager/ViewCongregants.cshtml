@model IEnumerable<DonorTrackingSystem.Models.Congregant>
@{
    ViewData["Title"] = "View Congregants";
}

<!-- This will be live for sprint 2 -->
<div class="container mt-4">
    <!-- Page header -->
    <div class="row mb-3">
        <div class="col-12">
            <h2>Congregants (Church Members)</h2>
            <hr />
        </div>
    </div>

    <!-- Success message notification -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Navigation buttons -->
    <div class="d-flex justify-content-between mb-3">
        <a asp-action="AddCongregant" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Congregant
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-house"></i> Back to Dashboard
        </a>
    </div>

    <!-- Main congregants table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Phone</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var congregant in Model)
                                    {
                                        <tr>
                                            <td>@congregant.Name</td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(congregant.EmailAddress))
                                                {
                                                    <span>@congregant.EmailAddress</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(congregant.PhoneNumber))
                                                {
                                                    <span>@congregant.PhoneNumber</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (congregant.ActiveStatus == DonorTrackingSystem.Models.ActiveStatus.CurrentMember)
                                                {
                                                    <span class="badge bg-success">Current Member</span>
                                                }
                                                else if (congregant.ActiveStatus == DonorTrackingSystem.Models.ActiveStatus.TransferredMembership)
                                                {
                                                    <span class="badge bg-warning">Transferred</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Left Church</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center">No congregants found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary card -->
    @if (Model != null && Model.Any())
    {
        <div class="row mt-3">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Summary</h5>
                        <p><strong>Total Congregants:</strong> @Model.Count()</p>
                        <p><strong>Current Members:</strong> @Model.Count(c => c.ActiveStatus == DonorTrackingSystem.Models.ActiveStatus.CurrentMember)</p>
                        <p><strong>Transferred Members:</strong> @Model.Count(c => c.ActiveStatus == DonorTrackingSystem.Models.ActiveStatus.TransferredMembership)</p>
                        <p><strong>Left Church:</strong> @Model.Count(c => c.ActiveStatus == DonorTrackingSystem.Models.ActiveStatus.LeftChurch)</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
