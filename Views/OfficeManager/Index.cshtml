@model IEnumerable<DonorTrackingSystem.Models.Congregant>
@{
    ViewData["Title"] = "Office Manager Dashboard";
}

<!-- Main dashboard container -->
<div class="container mt-4">
    <!-- Page header -->
    <div class="row">
        <div class="col-12">
            <h2 class="text-center">Office Manager Dashboard</h2>
            <hr />
        </div>
    </div>

    <!-- Success message notification (appears after recording a donation) -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Quick action buttons -->
    <div class="row mb-4 d-flex justify-content-between">
        <!-- Manage congregants card -->
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Congregants</h5>
                    <p>Manage members</p>
                    <a asp-action="ViewCongregants" class="btn btn-outline-secondary">
                        <i class="bi bi-people-fill"></i> Manage
                    </a>
                </div>
            </div>
        </div>
        <!-- Manage families card -->
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Family Groups</h5>
                    <p>Manage household relationships</p>
                    <a asp-action="ManageFamilies" class="btn btn-outline-secondary">
                        <i class="bi bi-house-heart"></i> Manage
                    </a>
                </div>
            </div>
        </div>
        <!-- Manage non-congregants card -->
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Non-Congregants</h5>
                    <p>Manage non-congregant donors</p>
                    <a asp-action="ViewNonCongregants" class="btn btn-outline-secondary">
                        <i class="bi bi-people"></i> Manage
                    </a>
                </div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Reports</h5>
                    <p>Forecasting, financial &amp; more</p>
                    <a asp-action="Reports" class="btn btn-outline-secondary">
                        <i class="bi bi-bar-chart-fill"></i> Reports
                    </a>
                </div>
            </div>
        </div>
        <!-- Support Staff Dashboard -->
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Support Staff Dashboard</h5>
                    <p>Access the capabilites of Support Staff</p>
                    <a asp-controller="SupportStaff" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-headset"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Congregant Donation History</h5>
                    <p>View giving patterns</p>
                    <a asp-action="ViewDonationHistory" class="btn btn-outline-secondary">
                        <i class="bi bi-clock-history"></i> View History
                    </a>
                </div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Non-Congregant Donation History</h5>
                    <p>View non-congregant giving patterns</p>
                    <a asp-action="ViewNonCongregantDonationHistory" class="btn btn-outline-secondary">
                        <i class="bi bi-clock-history"></i> View History
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>