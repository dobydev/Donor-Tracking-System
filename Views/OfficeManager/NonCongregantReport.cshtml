@model IEnumerable<DonorTrackingSystem.ViewModels.NonCongregantReportRow>
@{
    ViewData["Title"] = "Non-Congregant Report";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2>Non-Congregant Report</h2>
            <a asp-action="ExportNonCongregantReport" class="btn btn-outline-success">
                <i class="bi bi-download"></i> Export CSV
            </a>
        </div>
        <div class="col-12"><hr /></div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Contact Info</th>
                    <th>Last Donation Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model)
                {
                    <tr>
                        <td>@row.Name</td>
                        <td>@row.ContactInfo</td>
                        <td>@row.LastDonationDate?.ToString("MM/dd/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <a asp-action="Reports" class="btn btn-secondary mt-2"><i class="bi bi-arrow-left"></i> Back to Reports</a>
</div>
