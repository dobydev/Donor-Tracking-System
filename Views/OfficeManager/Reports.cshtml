@{
    ViewData["Title"] = "Reports";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="text-center">Reports</h2>
            <hr />
        </div>
    </div>

    <div class="row d-flex justify-content-center">
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card dashboard-card h-100">
                <div class="card-body d-flex flex-column">
                    <h5>Forecasting Report</h5>
                    <p class="flex-grow-1">Donor YTD, prior YTD, and prior year giving totals.</p>
                    <a asp-action="ForecastingReport" class="btn btn-outline-secondary"><i class="bi bi-graph-up-arrow"></i> View</a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card dashboard-card h-100">
                <div class="card-body d-flex flex-column">
                    <h5>Congregant Report</h5>
                    <p class="flex-grow-1">Member name, address, contact, birth date, and join date.</p>
                    <a asp-action="CongregantReport" class="btn btn-outline-secondary"><i class="bi bi-people-fill"></i> View</a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card dashboard-card h-100">
                <div class="card-body d-flex flex-column">
                    <h5>Non-Member Report</h5>
                    <p class="flex-grow-1">Non-member contact info and last donation date.</p>
                    <a asp-action="NonMemberReport" class="btn btn-outline-secondary"><i class="bi bi-people"></i> View</a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card dashboard-card h-100">
                <div class="card-body d-flex flex-column">
                    <h5>Financial Report</h5>
                    <p class="flex-grow-1">Monthly YTD vs prior YTD and year totals.</p>
                    <a asp-action="FinancialReport" class="btn btn-outline-secondary"><i class="bi bi-bar-chart-fill"></i> View</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
        </div>
    </div>
</div>
