@model DonorTrackingSystem.ViewModels.TaxLetterViewModel
@{
    ViewData["Title"] = $"Tax Letter – {Model.RecipientName} ({Model.Year})";
}

<!-- -->
@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
        // Export the tax letter to PDF
    function exportPdf() {
        const btn = document.getElementById('btn-export-pdf');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Generating…';

        const options = {
            margin: [0.5, 0.6],
            filename: 'TaxLetter_@(Model.RecipientName.Replace(" ", "_"))_@(Model.Year).pdf',
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2, useCORS: true },
            jsPDF: { unit: 'in', format: 'letter', orientation: 'portrait' },
            pagebreak: { mode: ['css', 'legacy'] }
        };

        html2pdf().set(options).from(document.getElementById('letters-export')).save().then(() => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-file-earmark-pdf"></i> Export PDF';
        });
    }
</script>
}

@await Html.PartialAsync("_TaxLetterStyles")

<!-- Screen controls -->
<div class="no-print container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Tax Letter — @Model.RecipientName (@Model.Year)</h2>
        <div class="d-flex gap-2">
            <button id="btn-export-pdf" onclick="exportPdf()" class="btn btn-primary" @(!Model.Donations.Any() ? "disabled" : "")>
                <i class="bi bi-file-earmark-pdf"></i> Export PDF
            </button>
            <a asp-action="SelectIndividualTaxLetter" asp-route-year="@Model.Year" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (!Model.Donations.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> No donations recorded for @Model.RecipientName in @Model.Year.
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Letter ready for <strong>@Model.RecipientName</strong>. Click <strong>Export PDF</strong> to download.
        </div>
    }
</div>

@if (Model.Donations.Any())
{
    <div id="letters-export">
        <div class="letter-page">
            <div class="letter-church-header">
                <h3 class="mt-3"><strong>Grace Community Church</strong></h3>
                <address>
                    123 Faith Avenue<br />
                    Springfield, IL 62701<br />
                    Phone: (555) 000-0000<br />
                    EIN: 00-0000000
                </address>
                <p>
                    @(new DateTime(Model.Year, 12, 31) <= DateTime.Today
                        ? new DateTime(Model.Year, 12, 31).ToString("MMMM d, yyyy")
                        : DateTime.Today.ToString("MMMM d, yyyy"))
                </p>
            </div>

            <div class="letter-recipient">
                <strong>@Model.RecipientName</strong><br />
                @if (!string.IsNullOrWhiteSpace(Model.RecipientAddress))
                {
                    @Model.RecipientAddress
                }
            </div>

            <strong>_________________________________________________</strong><br />
            <br />

            <div class="letter-body">
                <p>Dear @Model.RecipientName,</p>

                <p>
                    Thank you for your generous contributions to Grace Community Church during the @Model.Year
                    tax year. Your faithful giving makes a meaningful difference in our congregation and community.
                    This letter serves as your official tax-deductible contribution acknowledgement for the
                    @Model.Year calendar year.
                </p>

                <strong>_________________________________________________</strong><br />
                <br />

                <table class="letter-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Fund</th>
                            <th class="amount">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Donations)
                        {
                            <tr>
                                <td>@d.Date.ToString("MM/dd/yyyy")</td>
                                <td>@d.FundName</td>
                                <td class="amount">@d.Amount.ToString("C")</td>
                            </tr>
                        }
                        <tr class="letter-total-row">
                            <td colspan="2"><strong>Total Contributions for @Model.Year:</strong></td>
                            <td class="amount">@Model.Total.ToString("C")</td>
                        </tr>
                    </tbody>
                </table>

                <strong>_________________________________________________</strong><br />
                <br />

                <p><strong>No goods or services were provided in exchange for your contributions.</strong></p>
                <p>Please retain this letter as your official record for tax purposes.</p>
            </div>

            <div class="letter-signature">
                <div class="d-flex justify-content-start">
                    <p class="mb-0">
                        <strong>_________________________________</strong><br />
                        <strong>Office Manager</strong> |
                        Grace Community Church
                    </p>
                    <img src="~/Donor_Logo_2.png" alt="Church Logo" style="width: 150px;" />
                </div>
            </div>
        </div>
    </div>
}
