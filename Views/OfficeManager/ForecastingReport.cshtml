@model IEnumerable<DonorTrackingSystem.ViewModels.ForecastingReportRow>
@{
    ViewData["Title"] = "Forecasting Report";
    var year = DateTime.Today.Year;
    var priorYear = year - 1;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2>Forecasting Report</h2>
            <a asp-action="ExportForecastingReport" class="btn btn-outline-success">
                <i class="bi bi-download"></i> Export CSV
            </a>
        </div>
        <div class="col-12"><hr /></div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Donor Name / Company Name</th>
                    <th class="text-end">@year YTD</th>
                    <th class="text-end">@priorYear YTD</th>
                    <th class="text-end">@priorYear Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model)
                {
                    <tr>
                        <td>@row.DonorName</td>
                        <td class="text-end">@row.YtdTotal.ToString("C")</td>
                        <td class="text-end">@row.PriorYtdTotal.ToString("C")</td>
                        <td class="text-end">@row.PriorYearTotal.ToString("C")</td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-secondary fw-bold">
                <tr>
                    <td>Totals</td>
                    <td class="text-end">@Model.Sum(r => r.YtdTotal).ToString("C")</td>
                    <td class="text-end">@Model.Sum(r => r.PriorYtdTotal).ToString("C")</td>
                    <td class="text-end">@Model.Sum(r => r.PriorYearTotal).ToString("C")</td>
                </tr>
            </tfoot>
        </table>
    </div>

    <a asp-action="Reports" class="btn btn-secondary mt-2"><i class="bi bi-arrow-left"></i> Back to Reports</a>
</div>
