@{
    ViewData["Title"] = "Home - Donor Tracking System";
}

<!-- Custom styles for the home page -->
@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}



<div class="dashboard-card">

    <div class="dashboard-content">
        <div class="mission-section">
            <h2 class="mission-statement-title">Mission Statement</h2>
            <p class="mission-statement">
                Our mission is to faithfully serve our congregation by responsibly caring for
                member and donation records with accuracy, integrity, and transparency.
                Through this system, we seek to support the day-to-day work of our church staff,
                strengthen our stewardship, and ensure that every gift is handled with care and accountability.
            </p>
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="dashboard-section">
                <h3 class="dashboard-section-title">Access your Dashboard(s)</h3>
                <div class="dashboard-buttons">
                @if (User.IsInRole("Administrator"))
                {
                    <a asp-controller="Administrator" asp-action="Index" class="btn btn-dashboard btn-admin">
                        <i class="bi bi-shield-lock"></i>
                        <span>Administrator Dashboard</span>
                    </a>
                    <a asp-controller="OfficeManager" asp-action="Index" class="btn btn-dashboard btn-manager">
                        <i class="bi bi-person-workspace"></i>
                        <span>Office Manager Dashboard</span>
                    </a>
                    <a asp-controller="SupportStaff" asp-action="Index" class="btn btn-dashboard btn-staff">
                        <i class="bi bi-headset"></i>
                        <span>Support Staff Dashboard</span>
                    </a>
                }
                @if (User.IsInRole("Office Manager"))
                {
                    <a asp-controller="OfficeManager" asp-action="Index" class="btn btn-dashboard btn-manager">
                        <i class="bi bi-person-workspace"></i>
                        <span>Office Manager Dashboard</span>
                    </a>
                    <a asp-controller="SupportStaff" asp-action="Index" class="btn btn-dashboard btn-staff">
                        <i class="bi bi-headset"></i>
                        <span>Support Staff Dashboard</span>
                    </a>
                }
                @if (User.IsInRole("Support Staff"))
                {
                    <a asp-controller="SupportStaff" asp-action="Index" class="btn btn-dashboard btn-staff">
                        <i class="bi bi-headset"></i>
                        <span>Support Staff Dashboard</span>
                    </a>
                }
            </div>
        </div>
        }
    </div>
</div>