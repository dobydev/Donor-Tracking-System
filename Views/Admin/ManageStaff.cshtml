@model IEnumerable<DonorTrackingSystem.ViewModels.StaffListViewModel>
@{
    ViewData["Title"] = "Manage Staff";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2>Staff Management</h2>
            <div class="d-flex gap-2">
                <a asp-action="AddStaff" class="btn btn-primary">
                    <i class="bi bi-person-plus-fill"></i> Add Staff
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </div>
        <div class="col-12"><hr /></div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Staff ID</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td class="align-middle">@s.StaffId</td>
                                <td class="align-middle">
                                    @{
                                        var badgeClass = s.Role switch
                                        {
                                            "Administrator"  => "bg-danger",
                                            "Office Manager" => "bg-primary",
                                            "Support Staff"  => "bg-secondary",
                                            _                => "bg-dark"
                                        };
                                    }
                                    <span class="badge @badgeClass">@s.Role</span>
                                </td>
                                <td class="align-middle">
                                    @if (s.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Inactive</span>
                                    }
                                </td>
                                <td class="text-end align-middle">
                                    <a asp-action="EditStaff" asp-route-id="@s.Id"
                                       class="btn btn-sm btn-outline-primary me-1">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <form asp-action="DeleteStaff" method="post" class="d-inline"
                                          onsubmit="return confirm('Permanently delete staff account \'@s.StaffId\'? This cannot be undone.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@s.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">No staff accounts found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
