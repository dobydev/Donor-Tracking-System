@model DonorTrackingSystem.ViewModels.AddStaffViewModel
@{
    ViewData["Title"] = "Add Staff Account";
    var roles = ViewBag.Roles as string[] ?? Array.Empty<string>();
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2>Add Staff Account</h2>
            <a asp-action="ManageStaff" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
        <div class="col-12"><hr /></div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <form asp-action="AddStaff" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

                        <div class="mb-3">
                            <label asp-for="StaffId" class="form-label fw-bold"></label>
                            <input asp-for="StaffId" class="form-control" placeholder="e.g. 4000" />
                            <span asp-validation-for="StaffId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-bold"></label>
                            <input asp-for="Password" class="form-control" placeholder="Minimum 6 characters" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Role" class="form-label fw-bold"></label>
                            <select asp-for="Role" class="form-select">
                                <option value="">-- Select Role --</option>
                                @foreach (var role in roles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-person-plus-fill"></i> Create Account
                            </button>
                            <a asp-action="ManageStaff" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
