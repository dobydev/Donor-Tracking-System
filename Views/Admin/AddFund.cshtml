@model DonorTrackingSystem.Models.FundDesignation
@{
    ViewData["Title"] = "Add Fund Designation";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card">
                <div class="card-header bg-light text-black text-center">
                    <h3>Add Fund Designation</h3>
                </div>
                <div class="card-body">
                    <form asp-action="AddFund" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-info-circle"></i> Create a new fund to categorize donations.
                        </div>

                        <!-- Fund Name -->
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" type="text" placeholder="Enter fund name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <!-- Active Status -->
                        <div class="mb-3 form-check">
                            <input asp-for="ActiveStatus" class="form-check-input" type="checkbox" />
                            <label asp-for="ActiveStatus" class="form-check-label">Active (available for donation entry)</label>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="ManageFunds" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-save"></i> Save Fund
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
