@{
    ViewData["Title"] = "Administrator Dashboard";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="text-center">Administrator Dashboard</h2>
            <hr />
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mb-4 d-flex justify-content-center">
        <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Staff Management</h5>
                    <p>Add, edit, deactivate, and delete staff accounts</p>
                    <a asp-action="ManageStaff" class="btn btn-outline-secondary">
                        <i class="bi bi-people-fill"></i> Manage
                    </a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Fund Designations</h5>
                    <p>Create, edit, and deactivate donation funds</p>
                    <a asp-action="ManageFunds" class="btn btn-outline-secondary">
                        <i class="bi bi-tags-fill"></i> Manage
                    </a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Merge Congregants</h5>
                    <p>Merge duplicate congregant records with history preserved</p>
                    <a asp-action="MergeCongregants" class="btn btn-outline-secondary">
                        <i class="bi bi-union"></i> Merge
                    </a>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6 mb-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <h5>Merge Non-Congregants</h5>
                    <p>Merge duplicate non-congregant donor records with history preserved</p>
                    <a asp-action="MergeNonCongregants" class="btn btn-outline-secondary">
                        <i class="bi bi-union"></i> Merge
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
